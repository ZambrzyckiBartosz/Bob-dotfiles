{

    "layer": "top",

    "position": "top",

    "height": 16,

    "margin": "2 8 0 8",

    "spacing": 6,


    "modules-left": ["custom/apps", "clock", "hyprland/workspaces"],

    "modules-center": ["custom/media"],

    "modules-right": ["custom/recorder", "battery", "custom/volume","backlight", "custom/network","custom/git-guard", "custom/dashboard"],


    "custom/apps": {

        "format": "  bob",

        "on-click": "qs ipc call launcher toggle",

        "on-click-right": "qs ipc call wallpaper toggle",

        "tooltip": false

    },


    "clock": {
            "format": "󰥔 {:%H:%M}",
            "interval": 60
     },


    "hyprland/workspaces": {

        "format": "{name}",

        "on-click": "activate",

        "sort-by-number": true

    },


    "custom/media": {

        "exec": "playerctl metadata --format '{{ artist }} - {{ title }}' 2>/dev/null || echo ''",

        "interval": 2,

        "max-length": 40,

        "on-click": "playerctl play-pause",

        "on-click-right": "quickshell ipc call music toggle"

    },

    "custom/recorder": {
            "exec": "/home/bob/.config/scripts/recording.sh",
            "return-type": "json",
            "interval": 1,
            "on-click": "killall -SIGINT gpu-screen-recorder && notify-send 'Recording stopped'",
            "tooltip": true
        },

    "battery": {

        "format": "󰁹 {capacity}%",

        "format-charging": "󰂄 {capacity}%",

        "tooltip": false

    },


    "custom/volume": {

        "exec": "~/.config/waybar/scripts/volume.sh",

        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",

        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+",

        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-",

        "tooltip": false

    },

    "backlight": {
            "format": "{icon} {percent}%",
            "format-icons": ["󰃚", "󰃛", "󰃜", "󰃝", "󰃞", "󰃟", "󰃠"],
            "on-scroll-up": "brightnessctl set +5%",
            "on-scroll-down": "brightnessctl set 5%-",
            "tooltip": false
        },
    
    "custom/network": {

        "exec": "~/.config/waybar/scripts/network.sh",

        "interval": 5,

        "on-click": "qs ipc call wifi toggle",

        "on-click-right": "qs ipc call bluetooth toggle",

        "tooltip": false

    },

    "custom/git-guard": {
            "exec": "~/.config/scripts/GitGuard.sh",
            "return-type": "json",
            "interval": 900, 
            "format": "{}",
            "on-click": "kitty --directory ~/Git-Projects -e lazygit"
        },
                      
    "custom/dashboard": {

        "format": "󰍜",

        "on-click": "qs ipc call dashboard toggle",

        "tooltip": false

    }

} 
